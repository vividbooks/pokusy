# Zkopíruj na .env a doplň hodnoty (soubor .env je v .gitignore).

# Supabase — Project Settings → API (https://supabase.com/dashboard/project/njbtqmsxbyvpwigfceke/settings/api)
SUPABASE_URL=https://njbtqmsxbyvpwigfceke.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
# Veřejný anon (Project Settings → API) — pro volání Edge imagen-generate bez lokálního GEMINI_API_KEY
SUPABASE_ANON_KEY=

# Gemini — .env nebo app_config. Klíč zde = přímé volání Google (rychlejší než Edge + brána Supabase).
GEMINI_API_KEY=
# GEMINI_API_KEY_RAG=

# Volitelné
# GEMINI_EDGE_PREFER_REFERENCE_URL=0  # vynutit base64 místo URL u mq*.jpg z eBedox
# EBEDOX_THUMB_BASE=https://ebedox.cz/wp-content/uploads/2022/04
# GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview
# SUPABASE_STORAGE_BUCKET=gemini-images
# UPLOAD_PREFIX=manual/   # prefix pro npm run storage:upload (jen nahrání souborů)
# GEMINI_SAVE_LOCAL=1
